canvas {
  size 1920x1080
  fps 60
  duration 42s
  background #020308
}

camera {
  zoom 1
  x 0
  y 0
  rotation 0
}

import "./assets/Codex-app-background.jpg" as background
import "./assets/codex-color.svg" as logo
import "./assets/code-window.svg" as codeWindow
import "./assets/composition-stage.svg" as stage
import "./assets/export-panel.svg" as exportPanel

sequence codeLines {
  delay 17800ms
  gap 760ms
  items codeA codeB codeC codeD
}

background {
  cover
  center
  layer background
  opacity .26
  brightness .42
  scale 1.12
  overscan 1.35
  x -42
  y 18
}

effect atmosphereBg {
  layer background
  effect aurora
  opacity 0
  offset 0
}

effect heroBg {
  layer background
  effect heroGlow
  opacity 0
  offset 0
}

effect codeBg {
  layer background
  effect codeGlow
  opacity 0
  offset 0
}

effect finalBg {
  layer background
  effect heroGlow
  opacity 0
  offset 0
}

overlay shade {
  layer effects
  fill #000
  opacity .72
}

overlay cut {
  layer effects
  fill #020308
  opacity 0
}

overlay fade {
  layer effects
  fill #000
  opacity 1
}

logo {
  center
  layer hero
  width 210
  y -56
  opacity 0
  scale .82
  rotation -1
  shadow 28
}

codeWindow {
  center
  layer supporting
  width 680
  x -390
  y 30
  opacity 0
  scale .94
  shadow 30
}

stage {
  center
  layer supporting
  width 680
  x 390
  y 26
  opacity 0
  scale .94
  shadow 30
}

exportPanel {
  center
  layer supporting
  width 680
  y 42
  opacity 0
  scale .94
  shadow 26
}

text opening {
  value "What if a video could be written?"
  center
  layer text
  y 164
  font "Inter, SF Pro Display, Segoe UI, Arial, sans-serif"
  size 60
  weight 650
  color rgba(247,248,251,.92)
  tracking -1
  opacity 1
  textAnimation keynoteText(split words stagger 130ms duration 1.35s delay 1.8s ease power3.out exitAt 6.8s exitDuration 1s)
}

text heroTitle {
  value "Built with Codex"
  center
  layer text
  y 182
  font "Inter, SF Pro Display, Segoe UI, Arial, sans-serif"
  size 82
  weight 730
  color #f7f8fb
  tracking -1
  opacity 1
  textAnimation keynoteText(split words stagger 180ms duration 1.2s delay 9.1s ease power3.out exitAt 15s exitDuration 1s)
}

text heroSub {
  value "A scene file becomes a finished motion graphic."
  center
  layer text
  y 264
  font "Inter, SF Pro Text, Segoe UI, Arial, sans-serif"
  size 34
  weight 430
  color rgba(235,239,247,.76)
  opacity 1
  textAnimation keynoteText(split words stagger 95ms duration 1.15s delay 10.4s ease power3.out exitAt 15.4s exitDuration 1s)
}

text systemTitle {
  value "Write the scene. Motionly builds the timeline."
  center
  layer text
  y -288
  font "Inter, SF Pro Display, Segoe UI, Arial, sans-serif"
  size 58
  weight 680
  color #f7f8fb
  tracking -1
  opacity 1
  textAnimation keynoteText(split words stagger 120ms duration 1.2s delay 16.1s ease power3.out exitAt 28.5s exitDuration 1s)
}

text codeA {
  value "import \"codex-color.svg\""
  center
  layer text
  x -410
  y -100
  font "Cascadia Code, SF Mono, Consolas, monospace"
  size 28
  weight 450
  color rgba(244,247,255,.86)
  opacity 0
}

text codeB {
  value "logo { center }"
  center
  layer text
  x -410
  y -44
  font "Cascadia Code, SF Mono, Consolas, monospace"
  size 28
  weight 450
  color rgba(244,247,255,.72)
  opacity 0
}

text codeC {
  value "animation springIn()"
  center
  layer text
  x -410
  y 8
  font "Cascadia Code, SF Mono, Consolas, monospace"
  size 28
  weight 450
  color rgba(124,247,197,.92)
  opacity 0
}

text codeD {
  value "camera slowPush()"
  center
  layer text
  x -410
  y 60
  font "Cascadia Code, SF Mono, Consolas, monospace"
  size 28
  weight 450
  color rgba(138,180,255,.9)
  opacity 0
}

text exportTitle {
  value "Preview the story. Render the final."
  center
  layer text
  y -230
  font "Inter, SF Pro Display, Segoe UI, Arial, sans-serif"
  size 64
  weight 700
  color #f7f8fb
  tracking -1
  opacity 1
  textAnimation keynoteText(split words stagger 120ms duration 1.1s delay 29.2s ease power3.out exitAt 33.8s exitDuration 900ms)
}

text finalTitle {
  value "Motionly"
  center
  layer text
  y 126
  font "Inter, SF Pro Display, Segoe UI, Arial, sans-serif"
  size 92
  weight 740
  color #f7f8fb
  tracking -1
  opacity 1
  textAnimation keynoteText(split words stagger 0ms duration 1.2s delay 38s ease power3.out exitAt 40.6s exitDuration 900ms)
}

text finalSub {
  value "Motion graphics, written."
  center
  layer text
  y 212
  font "Inter, SF Pro Text, Segoe UI, Arial, sans-serif"
  size 36
  weight 450
  color rgba(235,239,247,.78)
  opacity 1
  textAnimation keynoteText(split words stagger 120ms duration 1.2s delay 39s ease power3.out exitAt 40.8s exitDuration 900ms)
}

animate camera {
  keyframes {
    0% { zoom 1 x 0 y 0 rotation 0 }
    15% { zoom 1.08 x -28 y 14 rotation 0 }
    27% { zoom 1.16 x 0 y -28 rotation 0 }
    36% { zoom 1.03 x 0 y -6 rotation 0 }
    47% { zoom 1.16 x -70 y 8 rotation 0 }
    60% { zoom 1.08 x -40 y -6 rotation 0 }
    72% { zoom 1.14 x 70 y -16 rotation 0 }
    84% { zoom 1.02 x 0 y 0 rotation 0 }
    100% { zoom 1.08 x 0 y 0 rotation 0 }
  }
  duration 42000ms
  easing smooth
}

animate background {
  keyframes {
    0% { opacity .18 brightness .34 scale 1.14 x -54 y 24 }
    18% { opacity .42 brightness .52 scale 1.08 x -24 y 8 }
    34% { opacity .3 brightness .44 scale 1.02 x 0 y -12 }
    43% { opacity .04 brightness .24 scale 1.1 x 54 y -30 }
    70% { opacity .02 brightness .2 scale 1.16 x 80 y -44 }
    84% { opacity .18 brightness .34 scale 1.08 x 16 y -10 }
    100% { opacity .06 brightness .24 scale 1.14 x 48 y -32 }
  }
  duration 42000ms
  easing smooth
}

animate atmosphereBg {
  keyframes {
    0% { opacity 0 offset 0 }
    8% { opacity .56 offset .12 }
    22% { opacity .42 offset .38 }
    31% { opacity 0 offset .62 }
    100% { opacity 0 offset 1 }
  }
  duration 42000ms
  easing smooth
}

animate heroBg {
  keyframes {
    0% { opacity 0 offset 0 }
    18% { opacity 0 offset 0 }
    25% { opacity .58 offset .18 }
    38% { opacity .46 offset .52 }
    45% { opacity 0 offset .82 }
    100% { opacity 0 offset 1 }
  }
  duration 42000ms
  easing smooth
}

animate codeBg {
  keyframes {
    0% { opacity 0 offset 0 }
    36% { opacity 0 offset 0 }
    43% { opacity .72 offset .2 }
    62% { opacity .58 offset .72 }
    70% { opacity .2 offset .94 }
    76% { opacity 0 offset 1 }
    100% { opacity 0 offset 1 }
  }
  duration 42000ms
  easing smooth
}

animate finalBg {
  keyframes {
    0% { opacity 0 offset 0 }
    68% { opacity 0 offset 0 }
    76% { opacity .58 offset .22 }
    94% { opacity .46 offset .74 }
    100% { opacity 0 offset 1 }
  }
  duration 42000ms
  easing smooth
}

animate shade {
  keyframes {
    0% { opacity .88 }
    16% { opacity .46 }
    34% { opacity .4 }
    41% { opacity .74 }
    50% { opacity .34 }
    66% { opacity .44 }
    76% { opacity .32 }
    100% { opacity .8 }
  }
  duration 42000ms
  easing smooth
}

animate cut {
  keyframes {
    0% { opacity 0 }
    37.5% { opacity 0 }
    39% { opacity .78 }
    40.5% { opacity 0 }
    68.5% { opacity 0 }
    70% { opacity .72 }
    71.5% { opacity 0 }
    100% { opacity 0 }
  }
  duration 42000ms
  easing smooth
}

animate fade {
  keyframes {
    0% { opacity 1 }
    7% { opacity 0 }
    94% { opacity 0 }
    100% { opacity 1 }
  }
  duration 42000ms
  easing smooth
}

animate logo {
  keyframes {
    0% { opacity 0 x 0 y -20 width 178 scale .82 rotation -1 }
    16% { opacity 0 x 0 y -20 width 178 scale .82 rotation -1 }
    25% { opacity 1 x 0 y -56 width 210 scale 1 rotation 0 }
    36% { opacity 1 x 0 y -70 width 210 scale 1.018 rotation 0 }
    41% { opacity 0 x 0 y -116 width 190 scale .94 rotation 0 }
    70% { opacity 0 x 0 y -116 width 190 scale .9 rotation 0 }
    84% { opacity 0 x 0 y -116 width 190 scale .9 rotation 0 }
    91% { opacity 1 x 0 y -82 width 190 scale 1 rotation 0 }
    96% { opacity 1 x 0 y -90 width 190 scale 1.012 rotation 0 }
    100% { opacity 0 x 0 y -122 width 190 scale .96 rotation 0 }
  }
  duration 42000ms
  easing smooth
}

animate codeWindow {
  keyframes {
    0% { opacity 0 x -470 y 86 scale .92 }
    38% { opacity 0 x -470 y 86 scale .92 }
    47% { opacity .98 x -390 y 30 scale 1 }
    66% { opacity .98 x -372 y 16 scale 1.012 }
    73% { opacity 0 x -320 y -24 scale .98 }
    100% { opacity 0 x -320 y -24 scale .98 }
  }
  duration 42000ms
  easing ease-out
}

animate stage {
  keyframes {
    0% { opacity 0 x 470 y 86 scale .92 }
    42% { opacity 0 x 470 y 86 scale .92 }
    51% { opacity .98 x 390 y 26 scale 1 }
    66% { opacity .98 x 372 y 14 scale 1.012 }
    73% { opacity 0 x 320 y -24 scale .98 }
    100% { opacity 0 x 320 y -24 scale .98 }
  }
  duration 42000ms
  easing ease-out
}

animate exportPanel {
  keyframes {
    0% { opacity 0 y 98 scale .92 }
    68% { opacity 0 y 98 scale .92 }
    76% { opacity .98 y 42 scale 1 }
    80% { opacity .98 y 30 scale 1.01 }
    84% { opacity 0 y -20 scale .98 }
    100% { opacity 0 y -20 scale .98 }
  }
  duration 42000ms
  easing ease-out
}

animate codeA {
  sequence codeLines
  from { opacity 0 y -68 }
  to { opacity 1 y -100 }
  duration 1100ms
  easing ease-out
}

animate codeB {
  sequence codeLines
  from { opacity 0 y -12 }
  to { opacity 1 y -44 }
  duration 1100ms
  easing ease-out
}

animate codeC {
  sequence codeLines
  from { opacity 0 y 40 }
  to { opacity 1 y 8 }
  duration 1100ms
  easing ease-out
}

animate codeD {
  sequence codeLines
  from { opacity 0 y 92 }
  to { opacity 1 y 60 }
  duration 1100ms
  easing ease-out
}

animate codeA {
  from { opacity 1 y -100 }
  to { opacity 0 y -132 }
  delay 28000ms
  duration 900ms
  easing ease-out
}

animate codeB {
  from { opacity 1 y -44 }
  to { opacity 0 y -76 }
  delay 28100ms
  duration 900ms
  easing ease-out
}

animate codeC {
  from { opacity 1 y 8 }
  to { opacity 0 y -24 }
  delay 28200ms
  duration 900ms
  easing ease-out
}

animate codeD {
  from { opacity 1 y 60 }
  to { opacity 0 y 28 }
  delay 28300ms
  duration 900ms
  easing ease-out
}
